# Database
DATABASE_URL=postgresql://fda_user:fda_pass@localhost:5433/fda_recalls
POSTGRES_USER=fda_user
POSTGRES_PASSWORD=fda_pass
POSTGRES_DB=fda_recalls

# FDA API (optional - increases rate limit from 1K to 120K requests/day)
FDA_API_KEY=

# Pipeline settings
BACKFILL_START_YEAR=2020
DAILY_LOOKBACK_DAYS=7
BATCH_SIZE=500

# Logging
LOG_LEVEL=INFO
